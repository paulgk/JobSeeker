# Upstash Redis — required in production for rate limiting
# Create a Redis database at console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: session cookie name (defaults to "jseeker_sid" in code)
# SESSION_COOKIE_NAME=jseeker_sid

# better-auth — Phase 4 Auth Foundation
# Generate BETTER_AUTH_SECRET with: openssl rand -base64 32
# BETTER_AUTH_SECRET must be 32+ chars and must never be committed to git
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth — create credentials at console.cloud.google.com
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Public app URL — exposed to the browser for the auth client
NEXT_PUBLIC_APP_URL=http://localhost:3000
